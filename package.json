{
  "name": "zyxacademy",
  "version": "1.0.alpha",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "cs:dev": "rm -rf .next node_modules && bun install && next dev --turbo",
    "build": "NODE_OPTIONS=\"--max-old-space-size=4096\" next build",
    "start": "next start",
    "preview": "NODE_OPTIONS=\"--max-old-space-size=4096\" next build --turbo && next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bunx tsx db/migrate.ts",
    "db:seed": "bunx tsx db/seed.ts",
    "db:push:prod": "bunx tsx db/push-prod.ts",
    "watch-start": "nodemon --watch app --watch components --watch styles -e js,jsx,ts,tsx,css --exec \"next build && next start\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1071.0",
    "@aws-sdk/s3-request-presigner": "^3.1071.0",
    "@cloudflare/workers-types": "^4.20260617.1",
